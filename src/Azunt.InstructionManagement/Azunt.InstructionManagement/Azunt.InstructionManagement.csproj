<Project Sdk="Microsoft.NET.Sdk">

    <PropertyGroup>
        <TargetFramework>net8.0</TargetFramework>
        <ImplicitUsings>enable</ImplicitUsings>
        <Nullable>enable</Nullable>

        <!-- 버전 정보 -->
        <VersionPrefix>1.0.0</VersionPrefix>
        <VersionSuffix></VersionSuffix>

        <!-- NuGet 메타데이터 -->
        <Title>Azunt.InstructionManagement</Title>
        <Description>Azunt.InstructionManagement is a reusable .NET module for managing instruction names and contents. It supports EF Core In-Memory for quick Blazor Server testing and SQL Server through EF Core, Dapper, and ADO.NET for production scenarios. Excel export uses Microsoft Open XML SDK instead of EPPlus.</Description>
        <PackageTags>Azunt, instruction, content, EFCore, InMemory, Dapper, ADO.NET, Blazor, SQLServer, OpenXML</PackageTags>

        <Authors>VisualAcademy</Authors>
        <Company>Hawaso</Company>

        <!-- NuGet 링크 및 저장소 -->
        <PackageProjectUrl>https://github.com/VisualAcademy/Azunt.InstructionManagement</PackageProjectUrl>
        <RepositoryUrl>https://github.com/VisualAcademy/Azunt.InstructionManagement</RepositoryUrl>
        <RepositoryType>git</RepositoryType>

        <!-- 저작권 -->
        <Copyright>© 2026 Hawaso. All rights reserved.</Copyright>

        <!-- NuGet package files -->
        <PackageReadmeFile>README.md</PackageReadmeFile>
        <PackageLicenseFile>LICENSE</PackageLicenseFile>
    </PropertyGroup>

    <ItemGroup>
        <!-- Dul.dll은 사용하지 않습니다. ArticleSet/FilterOptions는 이 패키지 내부의 경량 타입을 사용합니다. -->
        <PackageReference Include="Azunt" Version="1.2.3" />
        <PackageReference Include="Dapper" Version="2.1.79" />
        <PackageReference Include="DocumentFormat.OpenXml" Version="3.0.2" />
        <PackageReference Include="Microsoft.EntityFrameworkCore" Version="8.0.0" />
        <PackageReference Include="Microsoft.EntityFrameworkCore.InMemory" Version="8.0.0" />
        <PackageReference Include="Microsoft.EntityFrameworkCore.SqlServer" Version="8.0.0" />
        <PackageReference Include="Microsoft.Extensions.Configuration.Abstractions" Version="8.0.0" />
    </ItemGroup>



    <!-- Include solution-root README and LICENSE in the NuGet package -->
    <ItemGroup>
        <None Include="..\..\..\README.md" Pack="true" PackagePath="" />
        <None Include="..\..\..\LICENSE" Pack="true" PackagePath="" />
    </ItemGroup>

</Project>
